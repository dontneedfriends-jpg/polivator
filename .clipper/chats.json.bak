        "role": "assistant",
        "content": "{\"type\":\"code\",\"content\":\"Переписать src/main.cpp для работы с SensorManager (многодатчиковый режим) и новым интерфейсом Calibration. Привести структуру в соответствие с рефакторингом.\\n\\n```cpp\\n#include <Arduino.h>\\n#include <WiFi.h>\\n#include \\\"Sensor.h\\\"\\n#include \\\"Calibration.h\\\"\\n#include \\\"Display.h\\\"\\n#include \\\"WebServer.h\\\"\\n#include \\\"Common/Types.h\\\"\\n\\n// Пять датчиков на GPIO6-10 (ADC1)\\nconst uint8_t sensorPins[MAX_SENSORS] = {6, 7, 8, 9, 10};\\n\\nCalibration calibration;\\nSensorManager sensorManager;\\nDisplay display;\\nWebServer webServer(&sensorManager, &calibration, &display);\\n\\nbool calibrating = false;\\nuint8_t activeSensorForSerial = 0; // индекс датчика для serial-калибровки\\n\\nvoid setup() {\\n  Serial.begin(115200);\\n  delay(1000);\\n  Serial.println(\\\"\\\\n=== Polivator Multi-Sensor ===\\\");\\n  \\n  calibration.begin(sensorPins, MAX_SENSORS);\\n  sensorManager.begin(&calibration);\\n  display.begin();\\n  webServer.begin();\\n  \\n  // Отобразить статус после запуска\\n  sensorManager.readAll();\\n  display.showStatus(\\n    sensorManager.getPercent(0),\\n    sensorManager.getRaw(0),\\n    false,\\n    WiFi.status() == WL_CONNECTED ? \\\"connected\\\" : (WiFi.getMode() == WIFI_AP ? \\\"ap\\\" : \\\"disconnected\\\")\\n  );\\n  Serial.println(\\\"Setup complete.\\\");\\n}\\n\\nvoid handleSerialCommands() {\\n  if (!Serial.available()) return;\\n  char c = Serial.read();\\n  \\n  if (c == 'c' || c == 'C') {\\n    calibrating = !calibrating;\\n    if (calibrating) {\\n      Serial.println(\\\"Calibration mode ON. Select sensor: 0-\\\" + String(MAX_SENSORS-1));\\n      Serial.println(\\\"Send 0..4 to select sensor, then 'd' dry, 'w' wet, 'r' reset.\\\");\\n      display.showCalibrationScreen(\\\"Calibration mode\\\");\\n    } else {\\n      Serial.println(\\\"Calibration mode OFF\\\");\\n    }\\n    return;\\n  }\\n  \\n  if (!calibrating) return;\\n  \\n  // Выбор датчика цифрой 0-4\\n  if (c >= '0' && c <= '4') {\\n    activeSensorForSerial = c - '0';\\n    Serial.print(\\\"Selected sensor #\\\");\\n    Serial.println(activeSensorForSerial);\\n    display.showMessage(\\\"Sensor \\\" + String(activeSensorForSerial));\\n    return;\\n  }\\n  \\n  uint8_t idx = activeSensorForSerial;\\n  \\n  if (c == 'd') {\\n    int raw = sensorManager.getRaw(idx);\\n    calibration.setDryValue(idx, raw);\\n    sensorManager.setCalibration(idx, calibration.getDryValue(idx), calibration.getWetValue(idx));\\n    display.showMessage(\\\"Dry set S\\\" + String(idx));\\n    Serial.print(\\\"Dry calibration set for sensor \\\");\\n    Serial.println(idx);\\n  } else if (c == 'w') {\\n    int raw = sensorManager.getRaw(idx);\\n    calibration.setWetValue(idx, raw);\\n    sensorManager.setCalibration(idx, calibration.getDryValue(idx), calibration.getWetValue(idx));\\n    display.showMessage(\\\"Wet set S\\\" + String(idx));\\n    Serial.print(\\\"Wet calibration set for sensor \\\");\\n    Serial.println(idx);\\n  } else if (c == 'r') {\\n    calibration.resetToDefaults(idx);\\n    sensorManager.setCalibration(idx, calibration.getDryValue(idx), calibration.getWetValue(idx));\\n    display.showMessage(\\\"Reset S\\\" + String(idx));\\n    Serial.print(\\\"Calibration reset for sensor \\\");\\n    Serial.println(idx);\\n  } else if (c == 's') {\\n    // Показать статус всех датчиков\\n    for (int i = 0; i < MAX_SENSORS; i++) {\\n      Serial.print(\\\"S\\\");\\n      Serial.print(i);\\n      Serial.print(\\\": raw=\\\");\\n      Serial.print(sensorManager.getRaw(i));\\n      Serial.print(\\\" %=\\\");\\n      Serial.print(sensorManager.getPercent(i));\\n      Serial.print(\\\" dry=\\\");\\n      Serial.print(calibration.getDryValue(i));\\n      Serial.print(\\\" wet=\\\");\\n      Serial.print(calibration.getWetValue(i));\\n      Serial.print(\\\" pin=\\\");\\n      Serial.println(calibration.getPin(i));\\n    }\\n  }\\n}\\n\\nvoid loop() {\\n  static unsigned long lastSensorRead = 0;\\n  static unsigned long lastDisplayUpdate = 0;\\n  \\n  handleSerialCommands();\\n  webServer.handleClient();\\n  \\n  unsigned long now = millis();\\n  \\n  // Чтение датчиков каждые 2 секунды\\n  if (now - lastSensorRead >= 2000) {\\n    sensorManager.readAll();\\n    // Отправить SSE\\n    webServer.sendStatusEvent(&sensorManager);\\n    lastSensorRead = now;\\n  }\\n  \\n  // Обновление дисплея каждые 10 секунд\\n  if (now - lastDisplayUpdate >= 10000) {\\n    if (calibrating) {\\n      display.showCalibrationScreen(\\\"Calibration mode\\\");\\n    } else {\\n      // Показываем первый датчик (или в будущем все)\\n      display.showStatus(\\n        sensorManager.getPercent(0),\\n        sensorManager.getRaw(0),\\n        false,\\n        WiFi.status() == WL_CONNECTED ? \\\"connected\\\" : (WiFi.getMode() == WIFI_AP ? \\\"ap\\\" : \\\"disconnected\\\")\\n      );\\n    }\\n    lastDisplayUpdate = now;\\n  }\\n  \\n  delay(10);\\n}\\n```\\n\\nЗаменить src/main.cpp этим содержимым.\",\"params\":{\"files\":\"src/main.cpp\"},\"role\":\"architect\",\"skills\":[],\"_toolId\":\"tool-1781468675746\"}"
