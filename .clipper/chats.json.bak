        "content": "Read lib/WebServer/WebServer.cpp (lines 201-314 of 314, 10728 bytes)\n201:   \n202:   // GET /api/calibration\n203:   server.on(\"/api/calibration\", HTTP_GET, [this](AsyncWebServerRequest *request) {\n204:     AsyncResponseStream *response = request->beginResponseStream(\"application/json\");\n205:     JsonDocument doc;\n206:     JsonArray sensors = doc[\"sensors\"].to<JsonArray>();\n207:     for (int i = 0; i < MAX_SENSORS; i++) {\n208:       JsonObject sensor = sensors.add<JsonObject>();\n209:       sensor[\"name\"] = m_calibration->getName(i);\n210:       sensor[\"dry\"] = m_calibration->getDryValue(i);\n211:       sensor[\"wet\"] = m_calibration->getWetValue(i);\n212:     }\n213:     serializeJson(doc, *response);\n214:     request->send(response);\n215:   });\n216:   \n217:   // GET /wifi - captive portal page\n218:   server.on(\"/wifi\", HTTP_GET, [](AsyncWebServerRequest *request) {\n219:     String html = R\"rawliteral(\n220: <!DOCTYPE html>\n221: <html>\n222: <head>\n223: <title>Polivator WiFi Config</title>\n224: <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n225: <style>\n226: body { font-family: Arial; text-align: center; margin: 20px; }\n227: input { width: 90%; padding: 8px; margin: 10px 0; }\n228: button { padding: 10px 20px; background: #4CAF50; color: white; border: none; cursor: pointer; }\n229: </style>\n230: </head>\n231: <body>\n232: <h2>WiFi Configuration</h2>\n233: <form action=\"/wifi/connect\" method=\"POST\">\n234: <label for=\"ssid\">SSID:</label><br>\n235: <input type=\"text\" id=\"ssid\" name=\"ssid\" required><br>\n236: <label for=\"password\">Password:</label><br>\n237: <input type=\"password\" id=\"password\" name=\"password\"><br>\n238: <button type=\"submit\">Save and Connect</button>\n239: </form>\n240: </body>\n241: </html>\n242: )rawliteral\";\n243:     request->send(200, \"text/html\", html);\n244:   });\n245:   \n246:   // POST /wifi/connect\n247:   server.on(\"/wifi/connect\", HTTP_POST, [this](AsyncWebServerRequest *request) {\n248:     if (request->hasParam(\"ssid\", true)) {\n249:       String ssid = request->getParam(\"ssid\", true)->value();\n250:       String pass = request->hasParam(\"password\", true) ? request->getParam(\"password\", true)->value() : \"\";\n251:       preferences.putString(\"ssid\", ssid);\n252:       preferences.putString(\"pass\", pass);\n253:       request->send(200, \"text/plain\", \"Credentials saved. Rebooting...\");\n254:       delay(1000);\n255:       ESP.restart();\n256:     } else {\n257:       request->send(400, \"text/plain\", \"Missing ssid\");\n258:     }\n259:   });\n260:   \n261:   // GET /api/wifi\n262:   server.on(\"/api/wifi\", HTTP_GET, [this](AsyncWebServerRequest *request) {\n263:     AsyncResponseStream *response = request->beginResponseStream(\"application/json\");\n264:     JsonDocument doc;\n265:     doc[\"ssid\"] = preferences.getString(\"ssid\", \"\");\n266:     serializeJson(doc, *response);\n267:     request->send(response);\n268:   });\n269:   \n270:   // POST /api/config/wifi\n271:   server.on(\"/api/config/wifi\", HTTP_POST, [this](AsyncWebServerRequest *request) {\n272:     if (request->contentType() != \"application/json\") {\n273:       request->send(400, \"text/plain\", \"Content-Type must be application/json\");\n274:       return;\n275:     }\n276:     String body = request->arg(\"plain\");\n277:     JsonDocument doc;\n278:     DeserializationError error = deserializeJson(doc, body);\n279:     if (error) {\n280:       request->send(400, \"text/plain\", \"Invalid JSON\");\n281:       return;\n282:     }\n283:     const char* ssid = doc[\"ssid\"];\n284:     const char* pass = doc[\"pass\"];\n285:     if (!ssid) {\n286:       request->send(400, \"text/plain\", \"Missing 'ssid' field\");\n287:       return;\n288:     }\n289:     preferences.putString(\"ssid\", ssid);\n290:     if (pass) {\n291:       preferences.putString(\"pass\", pass);\n292:     } else {\n293:       preferences.putString(\"pass\", \"\");\n294:     }\n295:     request->send(200, \"text/plain\", \"Credentials saved. Rebooting...\");\n296:     delay(1000);\n297:     ESP.restart();\n298:   });\n299:   \n300:   // Handle 404\n301:   server.onNotFound([](AsyncWebServerRequest *request) {\n302:     request->send(404, \"text/plain\", \"Not found\");\n303:   });\n304:   \n305:   // SSE events endpoint (optional)\n306:   events.onConnect([](AsyncEventSourceClient *client) {\n307:     if (client->lastId()) {\n308:       Serial.printf(\"Client reconnected! Last message ID: %u\\n\", client->lastId());\n309:     }\n310:     client->send(\"hello\", NULL, millis(), 1000);\n311:   });\n312:   server.addHandler(&events);\n313: }\n314: ",
