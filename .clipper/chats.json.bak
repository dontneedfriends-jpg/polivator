        "label": "write-file",
        "params": {
          "file": "lib/Display/Display.cpp",
          "content": "#include \"Display.h\"\n#include <SPI.h>\n#include <Fonts/FreeSans9pt7b.h>\n#include <Fonts/FreeSans12pt7b.h>\n#include <string.h>\n\nDisplay::Display() : m_display(GxEPD2_213_Z98c(EINK_CS, EINK_DC, EINK_RST, EINK_BUSY)), m_firstUpdate(true) {\n  memset(m_prevPercentages, -1, sizeof(m_prevPercentages));\n  memset(m_prevRaw, -1, sizeof(m_prevRaw));\n  m_prevWifi[0] = '\\0';\n}\n\nDisplay::~Display() {\n}\n\nvoid Display::begin() {\n  SPI.begin(EINK_SCLK, -1, EINK_MOSI);\n  m_display.init(115200, true, 4000000);\n  m_display.setRotation(1);\n  m_display.fillScreen(GxEPD_WHITE);\n  m_display.display(false);\n  m_firstUpdate = true;\n}\n\nvoid Display::showStatus(uint8_t sensorCount, const SensorConfig* configs, const int* percentages, const int* rawValues, const char* wifiStatus) {\n  // Check if anything changed\n  bool changed = m_firstUpdate;\n  if (!changed) {\n    if (sensorCount > 5) sensorCount = 5;\n    for (uint8_t i = 0; i < sensorCount; i++) {\n      if (percentages[i] != m_prevPercentages[i] || rawValues[i] != m_prevRaw[i]) {\n        changed = true;\n        break;\n      }\n    }\n    if (!changed && strcmp(wifiStatus, m_prevWifi) != 0) {\n      changed = true;\n    }\n  }\n  \n  if (!changed) {\n    return;\n  }\n  \n  m_display.setPartialWindow(0, 0, m_display.width(), m_display.height());\n  m_display.fillScreen(GxEPD_WHITE);\n  m_display.setTextColor(GxEPD_BLACK);\n  m_display.setFont(&FreeSans9pt7b);\n\n  int16_t yStart = 10;\n  int16_t yStep = 20;\n  char nameBuf[9];\n  char pctBuf[8];\n\n  for (uint8_t i = 0; i < sensorCount; i++) {\n    strncpy(nameBuf, configs[i].name, 8);\n    nameBuf[8] = '\\0';\n\n    if (configs[i].dryRaw != configs[i].wetRaw) {\n      snprintf(pctBuf, sizeof(pctBuf), \"%d%%\", percentages[i]);\n    } else {\n      snprintf(pctBuf, sizeof(pctBuf), \"?\");\n    }\n\n    m_display.setCursor(10, yStart + i * yStep);\n    m_display.print(nameBuf);\n    m_display.print(\"  \");\n    m_display.print(pctBuf);\n    m_display.print(\"  \");\n    m_display.println(rawValues[i]);\n\n    m_prevPercentages[i] = percentages[i];\n    m_prevRaw[i] = rawValues[i];\n  }\n\n  m_display.setCursor(10, yStart + sensorCount * yStep + 10);\n  m_display.print(\"WiFi: \");\n  m_display.println(wifiStatus);\n  \n  strncpy(m_prevWifi, wifiStatus, sizeof(m_prevWifi)-1);\n  m_prevWifi[sizeof(m_prevWifi)-1] = '\\0';\n\n  m_display.display(true);\n  m_firstUpdate = false;\n}\n\nvoid Display::showCalibrationScreen(const char* step) {\n  m_display.setFullWindow();\n  m_display.fillScreen(GxEPD_WHITE);\n  m_display.setTextColor(GxEPD_BLACK);\n  m_display.setFont(&FreeSans12pt7b);\n  \n  int16_t tbx, tby; uint16_t tbw, tbh;\n  m_display.getTextBounds(\"Calibrating...\", 0, 0, &tbx, &tby, &tbw, &tbh);\n  m_display.setCursor((m_display.width() - tbw) / 2, tbh + 10);\n  m_display.println(\"Calibrating...\");\n  \n  if (step && step[0]) {\n    m_display.setFont(&FreeSans9pt7b);\n    m_display.getTextBounds(step, 0, 0, &tbx, &tby, &tbw, &tbh);\n    m_display.setCursor((m_display.width() - tbw) / 2, m_display.height() / 2);\n    m_display.println(step);\n  }\n  \n  m_display.display(false);\n  m_firstUpdate = true;\n}\n\nvoid Display::showMessage(const char* msg) {\n  m_display.setFullWindow();\n  m_display.fillScreen(GxEPD_WHITE);\n  m_display.setTextColor(GxEPD_BLACK);\n  m_display.setFont(&FreeSans9pt7b);\n  \n  int16_t tbx, tby; uint16_t tbw, tbh;\n  m_display.getTextBounds(msg, 0, 0, &tbx, &tby, &tbw, &tbh);\n  m_display.setCursor((m_display.width() - tbw) / 2, (m_display.height() + tbh) / 2);\n  m_display.println(msg);\n  \n  m_display.display(false);\n  m_firstUpdate = true;\n}\n\nvoid Display::deepSleep() {\n  m_display.powerOff();\n}\n"
        },
        "status": "running"
      },
