r (uint8_t i = 0; i < count; i++) {\n 46:                     configs[i].pin = defaultPins[i];\n 47:                     if (i < arr.size()) {\n 48:                         JsonObject obj = arr[i];\n 49:                         configs[i].dryRaw = obj[\"dryRaw\"] | 3000;\n 50:                         configs[i].wetRaw = obj[\"wetRaw\"] | 1200;\n 51:                         const char* name = obj[\"name\"] | \"\";\n 52:                         if (strlen(name) > 0) {\n 53:                             strncpy(configs[i].name, name, 31);\n 54:                             configs[i].name[31] = '\\0';\n 55:                         } else {\n 56:                             snprintf(configs[i].name, 32, \"Sensor %d\", i+1);\n 57:                         }\n 58:                         configs[i].enabled = obj[\"enabled\"] | true;\n 59:                     } else {\n 60:                         configs[i].dryRaw = 3000;\n 61:                         configs[i].wetRaw = 1200;\n 62:                         configs[i].enabled = true;\n 63:                         snprintf(configs[i].name, 32, \"Sensor %d\", i+1);\n 64:                     }\n 65:                 }\n 66:             }\n 67:         }\n 68:     }\n 69: }\n 70: \n 71: void Calibration::saveAllConfigs(const SensorConfig* configs, uint8_t count) {\n 72:     JsonDocument doc;\n 73:     JsonArray arr = doc.to<JsonArray>();\n 74:     for (uint8_t i = 0; i < count; i++) {\n 75:         JsonObject obj = arr.add<JsonObject>();\n 76:         obj[\"name\"] = configs[i].name;\n 77:         obj[\"dryRaw\"] = configs[i].dryRaw;\n 78:         obj[\"wetRaw\"] = configs[i].wetRaw;\n 79:         obj[\"enabled\"] = configs[i].enabled;\n 80:     }\n 81:     String jsonStr;\n 82:     serializeJson(doc, jsonStr);\n 83:     prefs.putString(\"config\", jsonStr);\n 84: }\n 85: \n 86: void Calibration::writeCalibration(const SensorConfig* configs, uint8_t count) {\n 87:     SensorConfig adjustedConfigs[MAX_SENSORS];\n 88:     for (uint8_t i = 0; i < count; i++) {\n 89:         adjustedConfigs[i] = configs[i];\n 90:         if (adjustedConfigs[i].wetRaw == adjustedConfigs[i].dryRaw) {\n 91:             if (adjustedConfigs[i].dryRaw > 0) {\n 92:                 adjustedConfigs[i].wetRaw = adjustedConfigs[i].dryRaw - 1;\n 93:             } else {\n 94:                 adjustedConfigs[i].dryRaw = adjustedConfigs[i].wetRaw + 1;\n 95:             }\n 96:         }\n 97:     }\n 98:     saveAllConfigs(adjustedConfigs, count);\n 99: }\n100: \n101: void Calibration::setDryRaw(uint8_t index, int value) {\n102:     if (index < m_count) {\n103:         m_configs[index].dryRaw = value;\n104:         writeCalibration(m_configs, m_count);\n105:     }\n106: }\n107: \n108: void Calibration::setWetRaw(uint8_t index, int value) {\n109:     if (index < m_count) {\n110:         m_configs[index].wetRaw = value;\n111:         writeCalibration(m_configs, m_count);\n112:     }\n113: }\n114: \n115: void Calibration::setName(uint8_t index, const char* name) {\n116:     if (index < m_count) {\n117:         strncpy(m_configs[index].name, name, 31);\n118:         m_configs[index].name[31] = '\\0';\n119:         writeCalibration(m_configs, m_count);\n120:     }\n121: }\n122: \n123: void Calibration::setDryValue(uint8_t index, int value) {\n124:     setDryRaw(index, value);\n125: }\n126: \n127: void Calibration::setWetValue(uint8_t index, int value) {\n128:     setWetRaw(index, value);\n129: }\n130: \n131: void Calibration::resetToDefaults(uint8_t index) {\n132:     if (index < m_count) {\n133:         m_configs[index].dryRaw = 3000;\n134:         m_configs[index].wetRaw = 1200;\n135:         m_configs[index].enabled = true;\n136:         writeCalibration(m_configs, m_count);\n137:     }\n138: }\n139: \n140: void Calibration::removeSensor(uint8_t index) {\n141:     if (index < m_count) {\n142:         m_configs[index].enabled = false;\n143:         strncpy(m_configs[index].name, \"---\", 31);\n144:         m_configs[index].name[