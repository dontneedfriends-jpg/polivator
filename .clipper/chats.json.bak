        "content": "Read src/main.cpp (lines 1-63 of 63, 1682 bytes)\n 1: #include <Arduino.h>\n 2: #include <WiFi.h>\n 3: #include \"Sensor.h\"\n 4: #include \"Calibration.h\"\n 5: #include \"Display.h\"\n 6: #include \"WebServer.h\"\n 7: \n 8: Sensor sensor(4);\n 9: Calibration calibration;\n10: Display display;\n11: WebServer webServer(&sensor, &calibration, &display);\n12: \n13: void setup() {\n14:   Serial.begin(115200);\n15:   sensor.begin();\n16:   calibration.begin();\n17:   display.begin();\n18:   // Load calibration into sensor\n19:   sensor.setCalibration(calibration.getDryValue(), calibration.getWetValue());\n20:   webServer.begin();\n21:   display.showStatus(sensor.readPercent(), sensor.readRaw(), false, WiFi.status() == WL_CONNECTED ? \"connected\" : \"disconnected\");\n22: }\n23: \n24: void loop() {\n25:   static unsigned long lastSensorRead = 0;\n26:   static unsigned long lastDisplayUpdate = 0;\n27:   static float lastMoisture = 0.0f;\n28:   static int lastRaw = 0;\n29:   static String lastWifiStatus = \"disconnected\";\n30:   static bool calibrating = false;\n31: \n32:   // Handle serial commands for calibration\n33:   if (Serial.available()) {\n34:     char c = Serial.read();\n35:     if (c == 'c' || c == 'C') {\n36:       calibrating = !calibrating;\n37:       if (calibrating) {\n38:         Serial.println(\"Calibration mode: ON\");\n39:       } else {\n40:         Serial.println(\"Calibration mode: OFF\");\n41:       }\n42:     }\n43:   }\n44: \n45:   webServer.handleClient();\n46: \n47:   unsigned long now = millis();\n48: \n49:   if (now - lastSensorRead >= 2000) {\n50:     lastMoisture = sensor.readPercent();\n51:     lastRaw = sensor.readRaw();\n52:     lastWifiStatus = WiFi.status() == WL_CONNECTED ? \"connected\" : (WiFi.getMode() == WIFI_AP ? \"ap\" : \"disconnected\");\n53:     lastSensorRead = now;\n54:   }\n55: \n56:   if (now - lastDisplayUpdate >= 10000) {\n57:     display.showStatus(lastMoisture, lastRaw, calibrating, lastWifiStatus.c_str());\n58:     lastDisplayUpdate = now;\n59:   }\n60: \n61:   delay(10);\n62: }\n63: ",
