n 54:     }\n 55:     const char* wifiStatus = WiFi.status() == WL_CONNECTED ? \"connected\" : (WiFi.getMode() == WIFI_AP ? \"ap\" : \"disconnected\");\n 56:     display.showStatus(count, configs, percentages, rawValues, wifiStatus);\n 57:   }\n 58:   esp_task_wdt_reset();\n 59:   Serial.println(\"Setup complete.\");\n 60: }\n 61: \n 62: void handleSerialCommands() {\n 63:   if (!Serial.available()) return;\n 64:   char c = Serial.read();\n 65:   \n 66:   if (c == 'c' || c == 'C') {\n 67:     calibrating = !calibrating;\n 68:     if (calibrating) {\n 69:       Serial.println(\"Calibration mode ON. Select sensor: 0-\" + String(MAX_SENSORS-1));\n 70:       Serial.println(\"Send 0..4 to select sensor, then 'd' dry, 'w' wet, 'r' reset.\");\n 71:       display.showCalibrationScreen(\"Calibration mode\");\n 72:     } else {\n 73:       Serial.println(\"Calibration mode OFF\");\n 74:     }\n 75:     return;\n 76:   }\n 77:   \n 78:   if (!calibrating) return;\n 79:   \n 80:   // Выбор датчика цифрой 0-4\n 81:   if (c >= '0' && c <= '4') {\n 82:     activeSensorForSerial = c - '0';\n 83:     Serial.print(\"Selected sensor #\");\n 84:     Serial.println(activeSensorForSerial);\n 85:     char buf[32];\n 86:     snprintf(buf, sizeof(buf), \"Sensor %u\", activeSensorForSerial);\n 87:     display.showMessage(buf);\n 88:     return;\n 89:   }\n 90:   \n 91:   uint8_t idx = activeSensorForSerial;\n 92:   \n 93:   if (c == 'd') {\n 94:     int raw = sensorManager.getRaw(idx);\n 95:     calibration.setDryValue(idx, raw);\n 96:     sensorManager.setCalibration(idx, calibration.getDryValue(idx), calibration.getWetValue(idx));\n 97:     {\n 98:       char buf[32];\n 99:       snprintf(buf, sizeof(buf), \"Dry set S%u\", idx);\n100:       display.showMessage(buf);\n101:     }\n102:     forceDisplayUpdate = true;\n103:     Serial.print(\"Dry calibration set for sensor \");\n104:     Serial.println(idx);\n105:   } else if (c == 'w') {\n106:     int raw = sensorManager.getRaw(idx);\n107:     calibration.setWetValue(idx, raw);\n108:     sensorManager.setCalibration(idx, calibration.getDryValue(idx), calibration.getWetValue(idx));\n109:     {\n110:       char buf[32];\n111:       snprintf(buf, sizeof(buf), \"Wet set S%u\", idx);\n112:       display.showMessage(buf);\n113:     }\n114:     forceDisplayUpdate = true;\n115:     Serial.print(\"Wet calibration set for sensor \");\n116:     Serial.println(idx);\n117:   } else if (c == 'r') {\n118:     calibration.resetToDefaults(idx);\n119:     sensorManager.setCalibration(idx, calibration.getDryValue(idx), calibration.getWetValue(idx));\n120:     {\n121:       char buf[32];\n122:       snprintf(buf, sizeof(buf), \"Reset S%u\", idx);\n123:       display.showMessage(buf);\n124:     }\n125:     forceDisplayUpdate = true;\n126:     Serial.print(\"Calibration reset for sensor \");\n127:     Serial.println(idx);\n128:   } else if (c == 's') {\n129:     // Показать статус всех датчиков\n130:     for (int i = 0; i < MAX_SENSORS; i++) {\n131:       Serial.print(\"S\");\n132:       Serial.print(i);\n133:       Serial.print(\": raw=\");\n134:       Serial.print(sensorManager.getRaw(i));\n135:       Serial.print(\" %=\");\n136:       Serial.print(sensorManager.getPercent(i));\n137:       Serial.print(\" dry=\");\n138:       Serial.print(calibration.getDryValue(i));\n139:       Serial.print(\" wet=\");\n140:       Serial.print(calibration.getWetValue(i));\n141:       Serial.print(\" pin=\");\n142:       Serial.println(calibration.getPin(i));\n143:     }\n144:   }\n145: }\n146: \n147: void loop() {\n148:   esp_task_wdt_reset();\n149:   static unsigned long lastSensorRead = 0;\n150:   static unsigned long lastDisplayUpdate = 0;\n151:   \n152:   handleSerialCommands();\n153:   webServer.handleClient();\n154:   ArduinoOTA.handle();\n155:   esp_task_wdt_reset();\n156:   \n157:   unsigned long now = millis();\n158:   \n159:   // Чтение датчиков каждые 2 секунды\n160:   if (now - lastSensorRead >= 2000) {\n161:     sensorManager.readAll();\n162:     // Отправить SSE\n163:     webServer.sendStatusEvent(&sensorManager);\n164:     lastSensorRead = now;\n165:     esp_task_wdt_reset();\n166:   }\n167:   \n168:   // Обнаружение изменений конфигурации (калибровочных значений)\n169:   static bool configInit = false;\n170:   static int prevDry[MAX_SENSORS];\n171:   static int prevWet[MAX_SENSORS];\n172:   if (!configInit) {\n173:     for (uint8_t i = 0; i < MAX_SENSORS; i++) {\n174:       prevDry[i] = calibration.getDryValue(i);\n175:       prevWet[i] = calibration.getWetValue(i);\n176:     }\n177:     configInit = true;\n178:   }\n179:   bool configChanged = false;\n180:   for (uint8_t i = 0; i < MAX_SENSORS; i++) {\n181:     if (calibration.getDryValue(i) != prevDry[i] || calibration.getWetValue(i) != prevWet[i]) {\n182:       configChanged = true;\n183:       prevDry[i] = calibration.getDryValue(i);\n184:       prevWet[i] = calibration.getWetValue(i);\n185:     }\n186:   }\n187:   if (configChanged) {\n188:     forceDisplayUpdate = true;\n189:   }\n190:   \n191:   // Обновление дисплея каждые 30 секунд или при принудительном обновлении\n192:   if (now - lastDisplayUpdate >= 30000 || forceDisplayUpdate) {\n193:     forceDisplayUpdate = false;\n194:     if (calibrating) {\n195:       display.showCalibrationScreen(\"Calibration mode\");\n196:     } else {\n197:       // Показываем первый датчик (или в будущем все)\n198:       {\n199:         uint8_t count = sensorManager.getCount();\n200:         const SensorConfig* configs = calibration.getConfigs();\n-- More: 17 lines below. Use offset=201 to continue. --",
