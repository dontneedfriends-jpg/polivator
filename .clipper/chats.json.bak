        "content": "Read lib/WebServer/WebServer.cpp (lines 1-200 of 394, 13771 bytes)\n  1: #include \"WebServer.h\"\n  2: #include \"../Settings/Settings.h\"\n  3: #include <Arduino.h>\n  4: #include <ArduinoJson.h>\n  5: #include \"Sensor.h\"\n  6: #include \"Calibration.h\"\n  7: #include \"Display.h\"\n  8: #include \"index.h\"\n  9: #include <Update.h>\n 10: #include <esp_task_wdt.h>\n 11: \n 12: WebServer::WebServer(SensorManager* sensorManager, Calibration* calibration, Display* display, Settings* settings)\n 13:   : m_sensorManager(sensorManager), m_calibration(calibration), m_display(display), m_settings(settings), server(80) {\n 14: }\n 15: \n 16: WebServer::~WebServer() {\n 17: }\n 18: \n 19: void WebServer::begin() {\n 20:   Serial.println(\"Starting WebServer...\");\n 21:   preferences.begin(\"wifi\", false);\n 22:   \n 23:   String ssid = preferences.getString(\"ssid\", \"\");\n 24:   String pass = preferences.getString(\"pass\", \"\");\n 25:   \n 26:   if (ssid.length() > 0 && connectToSavedWiFi()) {\n 27:     Serial.println(\"Connected to saved WiFi.\");\n 28:   } else {\n 29:     setupAP();\n 30:   }\n 31:   \n 32:   setupRoutes();\n 33:   server.begin();\n 34:   Serial.println(\"WebServer started.\");\n 35: }\n 36: \n 37: void WebServer::handleClient() {\n 38:   if (WiFi.getMode() == WIFI_AP) {\n 39:     dnsServer.processNextRequest();\n 40:   }\n 41: }\n 42: \n 43: void WebServer::stop() {\n 44:   server.end();\n 45:   if (WiFi.getMode() == WIFI_AP) {\n 46:     dnsServer.stop();\n 47:     WiFi.softAPdisconnect(true);\n 48:   } else {\n 49:     WiFi.disconnect();\n 50:   }\n 51: }\n 52: \n 53: void WebServer::sendStatusEvent(SensorManager* sensorManager) {\n 54:   JsonDocument doc;\n 55:   JsonArray sensors = doc[\"sensors\"].to<JsonArray>();\n 56:   for (int i = 0; i < MAX_SENSORS; i++) {\n 57:     JsonObject sensor = sensors.add<JsonObject>();\n 58:     sensor[\"name\"] = m_calibration->getName(i);\n 59:     sensor[\"raw\"] = sensorManager->getRaw(i);\n 60:     sensor[\"percentage\"] = sensorManager->getPercent(i);\n 61:     sensor[\"voltage\"] = sensorManager->getVoltage(i);\n 62:     sensor[\"dry\"] = m_calibration->getDryValue(i);\n 63:     sensor[\"wet\"] = m_calibration->getWetValue(i);\n 64:     sensor[\"enabled\"] = m_calibration->getConfigs()[i].enabled;\n 65:   }\n 66:   doc[\"wifi\"] = WiFi.status() == WL_CONNECTED ? \"connected\" : (WiFi.getMode() == WIFI_AP ? \"ap\" : \"disconnected\");\n 67:   if (WiFi.status() == WL_CONNECTED) {\n 68:     doc[\"ssid\"] = WiFi.SSID();\n 69:   } else {\n 70:     doc[\"ssid\"] = preferences.getString(\"ssid\", \"\");\n 71:   }\n 72:   String output;\n 73:   serializeJson(doc, output);\n 74:   events.send(output.c_str(), \"status\", millis());\n 75: }\n 76: \n 77: bool WebServer::connectToSavedWiFi() {\n 78:   String ssid = preferences.getString(\"ssid\", \"\");\n 79:   String pass = preferences.getString(\"pass\", \"\");\n 80:   if (ssid.length() == 0) return false;\n 81:   \n 82:   WiFi.mode(WIFI_STA);\n 83:   WiFi.begin(ssid.c_str(), pass.c_str());\n 84:   \n 85:   unsigned long startAttempt = millis();\n 86:   while (WiFi.status() != WL_CONNECTED && millis() - startAttempt < 10000) {\n 87:     delay(100);\n 88:     esp_task_wdt_reset();\n 89:   }\n 90:   \n 91:   return WiFi.status() == WL_CONNECTED;\n 92: }\n 93: \n 94: void WebServer::setupAP() {\n 95:   WiFi.mode(WIFI_AP);\n 96:   IPAddress apIP(192, 168, 4, 1);\n 97:   WiFi.softAPConfig(apIP, apIP, IPAddress(255, 255, 255, 0));\n 98:   WiFi.softAP(\"Polivator-Config\");\n 99:   \n100:   dnsServer.start(53, \"*\", apIP);\n101: }\n102: \n103: int WebServer::getIndexFromParam(AsyncWebServerRequest *request) {\n104:   if (!request->hasParam(\"index\")) {\n105:     return -1;\n106:   }\n107:   String indexStr = request->getParam(\"index\")->value();\n108:   int index = indexStr.toInt();\n109:   if (index < 0 || index >= MAX_SENSORS) {\n110:     return -1;\n111:   }\n112:   return index;\n113: }\n114: \n115: void WebServer::setupRoutes() {\n116:   // Root: serve the web UI page\n117:   server.on(\"/\", HTTP_GET, [this](AsyncWebServerRequest *request) {\n118:     request->send_P(200, \"text/html\", index_html_content);\n119:   });\n120:   \n121:   // GET /api/status\n122:   server.on(\"/api/status\", HTTP_GET, [this](AsyncWebServerRequest *request) {\n123:     AsyncResponseStream *response = request->beginResponseStream(\"application/json\");\n124:     JsonDocument doc;\n125:     JsonArray sensors = doc[\"sensors\"].to<JsonArray>();\n126:     for (int i = 0; i < MAX_SENSORS; i++) {\n127:       JsonObject sensor = sensors.add<JsonObject>();\n128:       sensor[\"name\"] = m_calibration->getName(i);\n129:       sensor[\"raw\"] = m_sensorManager->getRaw(i);\n130:       sensor[\"percentage\"] = m_sensorManager->getPercent(i);\n131:       sensor[\"voltage\"] = m_sensorManager->getVoltage(i);\n132:       sensor[\"dry\"] = m_calibration->getDryValue(i);\n133:       sensor[\"wet\"] = m_calibration->getWetValue(i);\n134:       sensor[\"enabled\"] = m_calibration->getConfigs()[i].enabled;\n135:     }\n136:     doc[\"wifi\"] = WiFi.status() == WL_CONNECTED ? \"connected\" : (WiFi.getMode() == WIFI_AP ? \"ap\" : \"disconnected\");\n137:     serializeJson(doc, *response);\n138:     request->send(response);\n139:   });\n140: \n141:   // POST /api/calibrate/dry?index=0\n142:   server.on(\"/api/calibrate/dry\", HTTP_POST, [this](AsyncWebServerRequest *request) {\n143:     int index = getIndexFromParam(request);\n144:     if (index < 0) {\n145:       request->send(400, \"text/plain\", \"Missing or invalid 'index' query parameter\");\n146:       return;\n147:     }\n148:     int raw = m_sensorManager->getRaw(index);\n149:     m_calibration->setDryValue(index, raw);\n150:     m_sensorManager->setCalibration(index, m_calibration->getDryValue(index), m_calibration->getWetValue(index));\n151:     request->send(200, \"text/plain\", \"Dry threshold set for sensor \" + String(index));\n152:   });\n153:   \n154:   // POST /api/calibrate/wet?index=0\n155:   server.on(\"/api/calibrate/wet\", HTTP_POST, [this](AsyncWebServerRequest *request) {\n156:     int index = getIndexFromParam(request);\n157:     if (index < 0) {\n158:       request->send(400, \"text/plain\", \"Missing or invalid 'index' query parameter\");\n159:       return;\n160:     }\n161:     int raw = m_sensorManager->getRaw(index);\n162:     m_calibration->setWetValue(index, raw);\n163:     m_sensorManager->setCalibration(index, m_calibration->getDryValue(index), m_calibration->getWetValue(index));\n164:     request->send(200, \"text/plain\", \"Wet threshold set for sensor \" + String(index));\n165:   });\n166:   \n167:   // POST /api/calibrate/reset?index=0\n168:   server.on(\"/api/calibrate/reset\", HTTP_POST, [this](AsyncWebServerRequest *request) {\n169:     int index = getIndexFromParam(request);\n170:     if (index < 0) {\n171:       request->send(400, \"text/plain\", \"Missing or invalid 'index' query parameter\");\n172:       return;\n173:     }\n174:     m_calibration->resetToDefaults(index);\n175:     m_sensorManager->setCalibration(index, m_calibration->getDryValue(index), m_calibration->getWetValue(index));\n176:     request->send(200, \"text/plain\", \"Calibration reset for sensor \" + String(index));\n177:   });\n178:   \n179:   // POST /api/config/sensor?index=0  (body: {\"name\": \"Sensor1\"})\n180:   server.on(\"/api/config/sensor\", HTTP_POST, [this](AsyncWebServerRequest *request) {\n181:     int index = getIndexFromParam(request);\n182:     if (index < 0) {\n183:       request->send(400, \"text/plain\", \"Missing or invalid 'index' query parameter\");\n184:       return;\n185:     }\n186:     // Parse JSON body\n187:     if (!request->contentType().startsWith(\"application/json\")) {\n188:       request->send(400, \"text/plain\", \"Content-Type must be application/json\");\n189:       return;\n190:     }\n191:     String body = request->arg(\"plain\");\n192:     JsonDocument doc;\n193:     DeserializationError error = deserializeJson(doc, body);\n194:     if (error) {\n195:       request->send(400, \"text/plain\", \"Invalid JSON\");\n196:       return;\n197:     }\n198:     const char* name = doc[\"name\"];\n199:     if (name) {\n200:       m_calibration->setName(index, name);\n-- More: 194 lines below. Use offset=201 to continue. --",
