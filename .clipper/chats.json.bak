lues\n110:     for (uint8_t i = 0; i < sensorCount && i < 5; i++) {\n111:       m_prevPercentages[i] = percentages[i];\n112:       m_prevRaw[i] = rawValues[i];\n113:     }\n114:     strncpy(m_prevWifi, wifiStatus, sizeof(m_prevWifi)-1);\n115:     m_prevWifi[sizeof(m_prevWifi)-1] = '\\0';\n116:   } while (m_display.nextPage());\n117:   \n118:   m_firstUpdate = false;\n119: }\n120: \n121: void Display::showCalibrationScreen(const char* step) {\n122:   m_display.setFullWindow();\n123:   m_display.firstPage();\n124:   do {\n125:     m_display.fillScreen(GxEPD_WHITE);\n126:     m_display.setTextColor(GxEPD_BLACK);\n127:     m_display.setFont(&FreeMonoBold9pt7b);\n128:     \n129:     int16_t tbx, tby; uint16_t tbw, tbh;\n130:     m_display.getTextBounds(\"Calibrating...\", 0, 0, &tbx, &tby, &tbw, &tbh);\n131:     m_display.setCursor((m_display.width() - tbw) / 2, tbh + 10);\n132:     m_display.println(\"Calibrating...\");\n133:     \n134:     if (step && step[0]) {\n135:       m_display.getTextBounds(step, 0, 0, &tbx, &tby, &tbw, &tbh);\n136:       m_display.setCursor((m_display.width() - tbw) / 2, m_display.height() / 2);\n137:       m_display.println(step);\n138:     }\n139:   } while (m_display.nextPage());\n140:   m_firstUpdate = true;\n141: }\n142: \n143: void Display::showMessage(const char* msg) {\n144:   m_display.setFullWindow();\n145:   m_display.firstPage();\n146:   do {\n147:     m_display.fillScreen(GxEPD_WHITE);\n148:     m_display.setTextColor(GxEPD_BLACK);\n149:     m_display.setFont(&FreeMonoBold9pt7b);\n150:     \n151:     int16_t tbx, tby; uint16_t tbw, tbh;\n152:     m_display.getTextBounds(msg, 0, 0, &tbx, &tby, &tbw, &tbh);\n153:     m_display.setCursor((m_display.width() - tbw) / 2, (m_display.height() + tbh) / 2);\n154:     m_display.println(msg);\n155:   } while (m_display.nextPage());\n156:   m_firstUpdate = true;\n157: }\n158: \n159: void Display::deepSleep() {\n160:   m_display.powerOff();\n161: }\n162: \n163: void Display::forceFullRefresh() {