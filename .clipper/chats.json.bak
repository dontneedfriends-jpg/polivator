        "content": "Read lib/Display/Display.cpp (lines 1-131 of 131, 3707 bytes)\n  1: #include \"Display.h\"\n  2: #include <SPI.h>\n  3: #include <Fonts/FreeSans9pt7b.h>\n  4: #include <Fonts/FreeSans12pt7b.h>\n  5: #include <string.h>\n  6: \n  7: Display::Display() : m_firstUpdate(true) {\n  8:   memset(m_prevPercentages, -1, sizeof(m_prevPercentages));\n  9:   memset(m_prevRaw, -1, sizeof(m_prevRaw));\n 10:   m_prevWifi[0] = '\\0';\n 11: }\n 12: \n 13: Display::~Display() {\n 14: }\n 15: \n 16: void Display::begin() {\n 17:   SPI.begin(EINK_SCLK, -1, EINK_MOSI);\n 18:   m_display.init(115200, true);\n 19:   m_display.setRotation(1);\n 20:   m_display.fillScreen(GxEPD_WHITE);\n 21:   m_display.display(false);\n 22:   m_firstUpdate = true;\n 23: }\n 24: \n 25: void Display::showStatus(uint8_t sensorCount, const SensorConfig* configs, const int* percentages, const int* rawValues, const char* wifiStatus) {\n 26:   // Check if anything changed\n 27:   bool changed = m_firstUpdate;\n 28:   if (!changed) {\n 29:     if (sensorCount > 5) sensorCount = 5;\n 30:     for (uint8_t i = 0; i < sensorCount; i++) {\n 31:       if (percentages[i] != m_prevPercentages[i] || rawValues[i] != m_prevRaw[i]) {\n 32:         changed = true;\n 33:         break;\n 34:       }\n 35:     }\n 36:     if (!changed && strcmp(wifiStatus, m_prevWifi) != 0) {\n 37:       changed = true;\n 38:     }\n 39:   }\n 40:   \n 41:   if (!changed) {\n 42:     return;\n 43:   }\n 44:   \n 45:   m_display.setPartialWindow(0, 0, m_display.width(), m_display.height());\n 46:   m_display.firstPage();\n 47:   do {\n 48:     m_display.fillScreen(GxEPD_WHITE);\n 49:     m_display.setTextColor(GxEPD_BLACK);\n 50:     m_display.setFont(&FreeSans9pt7b);\n 51: \n 52:     int16_t yStart = 10;\n 53:     int16_t yStep = 20;\n 54:     char nameBuf[9];\n 55:     char pctBuf[8];\n 56: \n 57:     for (uint8_t i = 0; i < sensorCount; i++) {\n 58:       strncpy(nameBuf, configs[i].name, 8);\n 59:       nameBuf[8] = '\\0';\n 60: \n 61:       if (configs[i].dryRaw != configs[i].wetRaw) {\n 62:         snprintf(pctBuf, sizeof(pctBuf), \"%d%%\", percentages[i]);\n 63:       } else {\n 64:         snprintf(pctBuf, sizeof(pctBuf), \"?\");\n 65:       }\n 66: \n 67:       m_display.setCursor(10, yStart + i * yStep);\n 68:       m_display.print(nameBuf);\n 69:       m_display.print(\"  \");\n 70:       m_display.print(pctBuf);\n 71:       m_display.print(\"  \");\n 72:       m_display.println(rawValues[i]);\n 73: \n 74:       m_prevPercentages[i] = percentages[i];\n 75:       m_prevRaw[i] = rawValues[i];\n 76:     }\n 77: \n 78:     m_display.setCursor(10, yStart + sensorCount * yStep + 10);\n 79:     m_display.print(\"WiFi: \");\n 80:     m_display.println(wifiStatus);\n 81:     \n 82:     strncpy(m_prevWifi, wifiStatus, sizeof(m_prevWifi)-1);\n 83:     m_prevWifi[sizeof(m_prevWifi)-1] = '\\0';\n 84:   } while (m_display.nextPage());\n 85:   \n 86:   m_firstUpdate = false;\n 87: }\n 88: \n 89: void Display::showCalibrationScreen(const char* step) {\n 90:   m_display.setFullWindow();\n 91:   m_display.firstPage();\n 92:   do {\n 93:     m_display.fillScreen(GxEPD_WHITE);\n 94:     m_display.setTextColor(GxEPD_BLACK);\n 95:     m_display.setFont(&FreeSans12pt7b);\n 96:     \n 97:     int16_t tbx, tby; uint16_t tbw, tbh;\n 98:     m_display.getTextBounds(\"Calibrating...\", 0, 0, &tbx, &tby, &tbw, &tbh);\n 99:     m_display.setCursor((m_display.width() - tbw) / 2, tbh + 10);\n100:     m_display.println(\"Calibrating...\");\n101:     \n102:     if (step && step[0]) {\n103:       m_display.setFont(&FreeSans9pt7b);\n104:       m_display.getTextBounds(step, 0, 0, &tbx, &tby, &tbw, &tbh);\n105:       m_display.setCursor((m_display.width() - tbw) / 2, m_display.height() / 2);\n106:       m_display.println(step);\n107:     }\n108:   } while (m_display.nextPage());\n109:   m_firstUpdate = true;\n110: }\n111: \n112: void Display::showMessage(const char* msg) {\n113:   m_display.setFullWindow();\n114:   m_display.firstPage();\n115:   do {\n116:     m_display.fillScreen(GxEPD_WHITE);\n117:     m_display.setTextColor(GxEPD_BLACK);\n118:     m_display.setFont(&FreeSans9pt7b);\n119:     \n120:     int16_t tbx, tby; uint16_t tbw, tbh;\n121:     m_display.getTextBounds(msg, 0, 0, &tbx, &tby, &tbw, &tbh);\n122:     m_display.setCursor((m_display.width() - tbw) / 2, (m_display.height() + tbh) / 2);\n123:     m_display.println(msg);\n124:   } while (m_display.nextPage());\n125:   m_firstUpdate = true;\n126: }\n127: \n128: void Display::deepSleep() {\n129:   m_display.powerOff();\n130: }\n131: ",
