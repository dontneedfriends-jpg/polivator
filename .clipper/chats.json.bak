tupAP() {\n 66:   WiFi.mode(WIFI_AP);\n 67:   WiFi.softAP(\"Polivator-Config\");\n 68:   IPAddress apIP(192, 168, 4, 1);\n 69:   WiFi.softAPConfig(apIP, apIP, IPAddress(255, 255, 255, 0));\n 70:   \n 71:   dnsServer.start(53, \"*\", apIP);\n 72: }\n 73: \n 74: void WebServer::setupRoutes() {\n 75:   // Root: redirect to /wifi when in AP mode, else show status\n 76:   server.on(\"/\", HTTP_GET, [this](AsyncWebServerRequest *request) {\n 77:     if (WiFi.getMode() == WIFI_AP) {\n 78:       request->redirect(\"/wifi\");\n 79:     } else {\n 80:       request->redirect(\"/api/status\");\n 81:     }\n 82:   });\n 83:   \n 84:   // GET /api/status\n 85:   server.on(\"/api/status\", HTTP_GET, [this](AsyncWebServerRequest *request) {\n 86:     AsyncResponseStream *response = request->beginResponseStream(\"application/json\");\n 87:     DynamicJsonDocument doc(256);\n 88:     doc[\"moisture\"] = m_sensor->readPercent();\n 89:     doc[\"raw\"] = m_sensor->readRaw();\n 90:     doc[\"voltage\"] = m_sensor->readVoltage();\n 91:     doc[\"dry\"] = m_calibration->getDryValue();\n 92:     doc[\"wet\"] = m_calibration->getWetValue();\n 93:     doc[\"wifi\"] = WiFi.status() == WL_CONNECTED ? \"connected\" : (WiFi.getMode() == WIFI_AP ? \"ap\" : \"disconnected\");\n 94:     serializeJson(doc, *response);\n 95:     request->send(response);\n 96:   });\n 97:   \n 98:   // POST /api/calibrate/dry\n 99:   server.on(\"/api/calibrate/dry\", HTTP_POST, [this](AsyncWebServerRequest *request) {\n100:     int raw = m_sensor->readRaw();\n101:     m_calibration->setDryValue(raw);\n102:     request->send(200, \"text/plain\", \"Dry threshold set\");\n103:   });\n104:   \n105:   // POST /api/calibrate/wet\n106:   server.on(\"/api/calibrate/wet\", HTTP_POST, [this](AsyncWebServerRequest *request) {\n107:     int raw = m_sensor->readRaw();\n108:     m_calibration->setWetValue(raw);\n109:     request->send(200, \"text/plain\", \"Wet threshold set\");\n110:   });\n111:   \n112:   // POST /api/calibrate/reset\n113:   server.on(\"/api/calibrate/reset\", HTTP_POST, [this](AsyncWebServerRequest *request) {\n114:     m_calibration->resetToDefaults();\n115:     request->send(200, \"text/plain\", \"Calibration reset\");\n116:   });\n117:   \n118:   // GET /api/calibration\n119:   server.on(\"/api/calibration\", HTTP_GET, [this](AsyncWebServerRequest *request) {\n120:     AsyncResponseStream *response = request->beginResponseStream(\"application/json\");\n121:     DynamicJsonDocument doc(128);\n122:     doc[\"dry\"] = m_calibration->getDryValue();\n123:     doc[\"wet\"] = m_calibration->getWetValue();\n124:     serializeJson(doc, *response);\n125:     request->send(response);\n126:   });\n127:   \n128:   // GET /wifi - captive portal page\n129:   server.on(\"/wifi\", HTTP_GET, [](AsyncWebServerRequest *request) {\n130:     String html = R\"rawliteral(\n131: <!DOCTYPE html>\n132: <html>\n133: <head>\n134: <title>Polivator WiFi Config</title>\n135: <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n136: <style>\n137: body { font-family: Arial; text-align: center; margin: 20px; }\n138: input { width: 90%; padding: 8px; margin: 10px 0; }\n139: button { padding: 10px 20px; background: #4CAF50; color: white; border: none; cursor: pointer; }\n140: </style>\n141: </head>\n142: <body>\n143: <h2>WiFi Configuration</h2>\n144: <form action=\"/wifi/connect\" method=\"POST\">\n145: <label for=\"ssid\">SSID:</label><br>\n146: <input type=\"text\" id=\"ssid\" name=\"ssid\" required><br>\n147: <label for=\"password\">Password:</label><br>\n148: <input type=\"password\" id=\"password\" name=\"password\"><br>\n149: <button type=\"submit\">Save and Connect</button>\n150: </form>\n151: </body>\n152: </html>\n153: )rawliteral\";\n154:     request->send(200, \"text/html\", html);\n155:   });\n156:   \n157:   // POST /wifi/connect\n158:   server.on(\"/wifi/connect\", HTTP_POST, [this](AsyncWebServerRequest *request) {\n159:     if (request->hasParam(\"ssid\", true)) {\n160:       String ssid = request->getParam(\"ssid\", true)->value();\n161:       String pass = request->hasParam(\"password\", true) ? request->getParam(\"password\", true)->value() : \"\";\n162:       preferences.putString(\"ssid\", ssid);\n163:       preferences.putString(\"pass\", pass);\n164:       request->send(200, \"text/plain\", \"Credentials saved. Rebooting...\");\n165:       delay(1000);\n166:       ESP.restart();\n167:     } else {\n168:       request->send(400, \"text/plain\", \"Missing ssid\");\n169:     }\n170:   });\n171:   \n172:   // Handle 404\n173:   server.onNotFound([](AsyncWebServerRequest *request) {\n174:     request->send(404, \"text/plain\", \"Not found\");\n175:   });\n176:   \n177:   // SSE events endpoint (optional)\n178:   events.onConnect([](AsyncEventSourceClient *client) {\n179:     if (client->lastId()) {\n180:       Serial.printf(\"Client reconnected! Last message ID: %u\\n\", client->lastId());\n181:     }\n182:     client->send(\"hello\", NULL, millis(), 1000);\n183:   });\n184:   server.addHandler(&events);\n185: }\n186: ",
