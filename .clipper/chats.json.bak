{\n156:       request->send(400, \"text/plain\", \"Missing or invalid 'index' query parameter\");\n157:       return;\n158:     }\n159:     int raw = m_sensorManager->getRaw(index);\n160:     m_calibration->setDryValue(index, raw);\n161:     m_sensorManager->setCalibration(index, m_calibration->getDryValue(index), m_calibration->getWetValue(index));\n162:     request->send(200, \"text/plain\", \"Dry threshold set for sensor \" + String(index));\n163:   });\n164:   \n165:   // POST /api/calibrate/wet?index=0\n166:   server.on(\"/api/calibrate/wet\", HTTP_POST, [this](AsyncWebServerRequest *request) {\n167:     if (!request->authenticate(DEFAULT_AUTH_USERNAME, DEFAULT_AUTH_PASSWORD)) {\n168:       request->requestAuthentication();\n169:       return;\n170:     }\n171:     int index = getIndexFromParam(request);\n172:     if (index < 0) {\n173:       request->send(400, \"text/plain\", \"Missing or invalid 'index' query parameter\");\n174:       return;\n175:     }\n176:     int raw = m_sensorManager->getRaw(index);\n177:     m_calibration->setWetValue(index, raw);\n178:     m_sensorManager->setCalibration(index, m_calibration->getDryValue(index), m_calibration->getWetValue(index));\n179:     request->send(200, \"text/plain\", \"Wet threshold set for sensor \" + String(index));\n180:   });\n181:   \n182:   // POST /api/calibrate/reset?index=0\n183:   server.on(\"/api/calibrate/reset\", HTTP_POST, [this](AsyncWebServerRequest *request) {\n184:     if (!request->authenticate(DEFAULT_AUTH_USERNAME, DEFAULT_AUTH_PASSWORD)) {\n185:       request->requestAuthentication();\n186:       return;\n187:     }\n188:     int index = getIndexFromParam(request);\n189:     if (index < 0) {\n190:       request->send(400, \"text/plain\", \"Missing or invalid 'index' query parameter\");\n191:       return;\n192:     }\n193:     m_calibration->resetToDefaults(index);\n194:     m_sensorManager->setCalibration(index, m_calibration->getDryValue(index), m_calibration->getWetValue(index));\n-- M