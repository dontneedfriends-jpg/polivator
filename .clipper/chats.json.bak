entById('btnDry').addEventListener('click', function() {\n259:     postAndMessage('/calibrate-dry', 'Dry threshold set!');\n260:   });\n261:   document.getElementById('btnWet').addEventListener('click', function() {\n262:     postAndMessage('/calibrate-wet', 'Wet threshold set!');\n263:   });\n264:   document.getElementById('btnReset').addEventListener('click', function() {\n265:     postAndMessage('/reset-calibration', 'Calibration reset!');\n266:   });\n267: \n268:   // Initialize chart with empty data\n269:   drawChart();\n270: })();\n271: </script>\n272: </body>\n273: </html>\n274: )rawliteral\";\n275: \n276: #endif\n277: ",
