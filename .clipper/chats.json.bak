auge .bg {\n 81:   stroke: #0f3460;\n 82: }\n 83: .gauge .fg {\n 84:   stroke: #00bcd4;\n 85:   stroke-linecap: round;\n 86:   transition: stroke-dashoffset 0.5s ease;\n 87: }\n 88: .gauge-value {\n 89:   position: absolute;\n 90:   top: 50%;\n 91:   left: 50%;\n 92:   transform: translate(-50%, -50%);\n 93:   font-size: 1.2rem;\n 94:   font-weight: bold;\n 95:   color: #00bcd4;\n 96: }\n 97: .metrics {\n 98:   display: flex;\n 99:   flex-wrap: wrap;\n100:   justify-content: space-between;\n-- More: 206 lines below. Use offset=101 to continue. --",
