        "content": "Read lib/WebServer/index.h (lines 101-300 of 306, 8118 bytes)\n101:   width: 100%;\n102: }\n103: .metric {\n104:   text-align: center;\n105:   font-size: 0.75rem;\n106: }\n107: .metric .label {\n108:   color: #7f8c8d;\n109:   text-transform: uppercase;\n110:   letter-spacing: 1px;\n111: }\n112: .metric .value {\n113:   font-weight: bold;\n114:   color: #00bcd4;\n115: }\n116: .btn-group {\n117:   display: flex;\n118:   flex-wrap: wrap;\n119:   gap: 5px;\n120:   justify-content: center;\n121: }\n122: .btn {\n123:   background: #0f3460;\n124:   color: #ddd;\n125:   border: none;\n126:   padding: 6px 10px;\n127:   border-radius: 6px;\n128:   cursor: pointer;\n129:   font-size: 0.75rem;\n130:   transition: background 0.2s;\n131: }\n132: .btn:hover {\n133:   background: #1a5276;\n134: }\n135: .btn:active {\n136:   background: #00bcd4;\n137:   color: #1a1a2e;\n138: }\n139: .message {\n140:   font-size: 0.85rem;\n141:   color: #00bcd4;\n142:   min-height: 1.2em;\n143:   text-align: center;\n144:   margin-top: 10px;\n145: }\n146: .wifi-status {\n147:   text-align: center;\n148:   margin-bottom: 20px;\n149:   font-size: 1rem;\n150: }\n151: </style>\n152: </head>\n153: <body>\n154: <div class=\"container\">\n155:   <div class=\"wifi-status\" id=\"wifiStatus\">WiFi: --</div>\n156:   <div class=\"sensors-wrapper\" id=\"sensorContainer\"></div>\n157:   <div class=\"message\" id=\"message\"></div>\n158: </div>\n159: \n160: <script>\n161: (function(){\n162:   const circumference = 2 * Math.PI * 56; // r=56 for 120px gauge\n163:   const messageDiv = document.getElementById('message');\n164:   const sensorContainer = document.getElementById('sensorContainer');\n165:   const wifiStatus = document.getElementById('wifiStatus');\n166:   \n167:   // Store references to cards\n168:   const cards = {};\n169: \n170:   function createOrUpdateSensorCard(index, data) {\n171:     let card = cards[index];\n172:     if (!card) {\n173:       // Create card\n174:       card = document.createElement('div');\n175:       card.className = 'card';\n176:       card.innerHTML = `\n177:         <input class=\"name-input\" id=\"name-${index}\" value=\"${data.name}\" />\n178:         <div class=\"gauge-wrapper\">\n179:           <div class=\"gauge\">\n180:             <svg viewBox=\"0 0 120 120\">\n181:               <circle class=\"bg\" cx=\"60\" cy=\"60\" r=\"56\"/>\n182:               <circle class=\"fg\" id=\"gauge-${index}\" cx=\"60\" cy=\"60\" r=\"56\" stroke-dasharray=\"${circumference}\" stroke-dashoffset=\"${circumference}\"/>\n183:             </svg>\n184:             <div class=\"gauge-value\" id=\"gauge-value-${index}\">0%</div>\n185:           </div>\n186:         </div>\n187:         <div class=\"metrics\">\n188:           <div class=\"metric\"><span class=\"label\">Raw</span><span class=\"value\" id=\"raw-${index}\">${data.raw}</span></div>\n189:           <div class=\"metric\"><span class=\"label\">Voltage</span><span class=\"value\" id=\"voltage-${index}\">${data.voltage}V</span></div>\n190:         </div>\n191:         <div class=\"btn-group\">\n192:           <button class=\"btn\" onclick=\"calibrateDry(${index})\">Dry</button>\n193:           <button class=\"btn\" onclick=\"calibrateWet(${index})\">Wet</button>\n194:           <button class=\"btn\" onclick=\"calibrateReset(${index})\">Reset</button>\n195:         </div>\n196:       `;\n197:       sensorContainer.appendChild(card);\n198:       cards[index] = card;\n199:       \n200:       // Add event listener for name change\n201:       const nameInput = card.querySelector(`#name-${index}`);\n202:       nameInput.addEventListener('change', function() {\n203:         const newName = this.value;\n204:         fetch(`/api/config/sensor/${index}`, {\n205:           method: 'POST',\n206:           headers: {'Content-Type': 'application/json'},\n207:           body: JSON.stringify({name: newName})\n208:         }).then(() => {\n209:           messageDiv.textContent = 'Name updated for sensor ' + index;\n210:           setTimeout(() => { messageDiv.textContent = ''; }, 2000);\n211:         }).catch(err => {\n212:           messageDiv.textContent = 'Error updating name';\n213:         });\n214:       });\n215:     }\n216:     // Update card elements\n217:     const fgCircle = card.querySelector(`#gauge-${index}`);\n218:     const gaugeValue = card.querySelector(`#gauge-value-${index}`);\n219:     const rawSpan = card.querySelector(`#raw-${index}`);\n220:     const voltageSpan = card.querySelector(`#voltage-${index}`);\n221:     const nameInput = card.querySelector(`#name-${index}`);\n222:     \n223:     if (data.percentage !== undefined) {\n224:       const offset = circumference - (data.percentage / 100) * circumference;\n225:       fgCircle.style.strokeDashoffset = offset;\n226:       gaugeValue.textContent = Math.round(data.percentage) + '%';\n227:     }\n228:     rawSpan.textContent = data.raw;\n229:     voltageSpan.textContent = (data.voltage).toFixed(2) + 'V';\n230:     if (data.name && nameInput.value !== data.name) {\n231:       nameInput.value = data.name;\n232:     }\n233:   }\n234: \n235:   // SSE connection\n236:   let eventSource = null;\n237:   function connectSSE() {\n238:     if (eventSource) eventSource.close();\n239:     eventSource = new EventSource('/events');\n240:     eventSource.addEventListener('status', function(e) {\n241:       try {\n242:         const data = JSON.parse(e.data);\n243:         if (data.sensors) {\n244:           data.sensors.forEach((sensor, index) => {\n245:             createOrUpdateSensorCard(index, sensor);\n246:           });\n247:         }\n248:         if (data.wifi) {\n249:           wifiStatus.textContent = 'WiFi: ' + data.wifi;\n250:         }\n251:       } catch(err) {\n252:         console.error('SSE parse error', err);\n253:       }\n254:     });\n255:     eventSource.onerror = function() {\n256:       eventSource.close();\n257:       setTimeout(connectSSE, 3000);\n258:     };\n259:   }\n260:   connectSSE();\n261: \n262:   // Calibration functions\n263:   function calibrateDry(index) {\n264:     messageDiv.textContent = 'Setting dry for sensor ' + index + '...';\n265:     fetch(`/api/calibrate/dry/${index}`, { method: 'POST' })\n266:       .then(async response => {\n267:         const text = await response.text();\n268:         messageDiv.textContent = text;\n269:         setTimeout(() => { messageDiv.textContent = ''; }, 2000);\n270:       })\n271:       .catch(err => {\n272:         messageDiv.textContent = 'Error: ' + err;\n273:       });\n274:   }\n275:   function calibrateWet(index) {\n276:     messageDiv.textContent = 'Setting wet for sensor ' + index + '...';\n277:     fetch(`/api/calibrate/wet/${index}`, { method: 'POST' })\n278:       .then(async response => {\n279:         const text = await response.text();\n280:         messageDiv.textContent = text;\n281:         setTimeout(() => { messageDiv.textContent = ''; }, 2000);\n282:       })\n283:       .catch(err => {\n284:         messageDiv.textContent = 'Error: ' + err;\n285:       });\n286:   }\n287:   function calibrateReset(index) {\n288:     messageDiv.textContent = 'Resetting calibration for sensor ' + index + '...';\n289:     fetch(`/api/calibrate/reset/${index}`, { method: 'POST' })\n290:       .then(async response => {\n291:         const text = await response.text();\n292:         messageDiv.textContent = text;\n293:         setTimeout(() => { messageDiv.textContent = ''; }, 2000);\n294:       })\n295:       .catch(err => {\n296:         messageDiv.textContent = 'Error: ' + err;\n297:       });\n298:   }\n299: })();\n300: </script>\n-- More: 6 lines below. Use offset=301 to continue. --",
