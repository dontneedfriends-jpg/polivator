  m_display.println(rawValues[i]);\n 56:   }\n 57: \n 58:   m_display.setCursor(10, yStart + sensorCount * yStep + 10);\n 59:   m_display.print(\"WiFi: \");\n 60:   m_display.println(wifiStatus);\n 61: \n 62:   m_display.display(false);\n 63: }\n 64: \n 65: void Display::showCalibrationScreen(const char* step) {\n 66:   m_display.setFullWindow();\n 67:   m_display.fillScreen(GxEPD_WHITE);\n 68:   m_display.setTextColor(GxEPD_BLACK);\n 69:   m_display.setFont(&FreeSans12pt7b);\n 70:   \n 71:   int16_t tbx, tby; uint16_t tbw, tbh;\n 72:   // Center \"Calibrating...\" at top\n 73:   m_display.getTextBounds(\"Calibrating...\", 0, 0, &tbx, &tby, &tbw, &tbh);\n 74:   m_display.setCursor((m_display.width() - tbw) / 2, tbh + 10);\n 75:   m_display.println(\"Calibrating...\");\n 76:   \n 77:   // Display step below if provided\n 78:   if (step && step[0]) {\n 79:     m_display.setFont(&FreeSans9pt7b);\n 80:     m_display.getTextBounds(step, 0, 0, &tbx, &tby, &tbw, &tbh);\n 81:     m_display.setCursor((m_display.width() - tbw) / 2, m_display.height() / 2);\n 82:     m_display.println(step);\n 83:   }\n 84:   \n 85:   m_display.display(false);\n 86: }\n 87: \n 88: void Display::showMessage(const char* msg) {\n 89:   m_display.setFullWindow();\n 90:   m_display.fillScreen(GxEPD_WHITE);\n 91:   m_display.setTextColor(GxEPD_BLACK);\n 92:   m_display.setFont(&FreeSans9pt7b);\n 93:   \n 94:   int16_t tbx, tby; uint16_t tbw, tbh;\n 95:   m_display.getTextBounds(msg, 0, 0, &tbx, &tby, &tbw, &tbh);\n 96:   m_display.setCursor((m_display.width() - tbw) / 2, (m_display.height() + tbh) / 2);\n 97:   m_display.println(msg);\n 98:   \n 99:   m_display.display(false);\n100: }\n101: \n102: void Display::deepSleep() {\n103:   m_display.powerOff(); // or m_display.hibernate()? powerOff is enough\n104:   // Optionally: m_display.sleep(); // but powerDown may be sufficient\n105: }\n106: ",
