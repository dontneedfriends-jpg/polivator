.setCalibration(calibration.getDryValue(), calibration.getWetValue());\n55:         display.showMessage(\"Wet calibration set\");\n56:         Serial.println(\"Wet calibration set\");\n57:       } else if (c == 'r') {\n58:         calibration.resetToDefaults();\n59:         sensor.setCalibration(calibration.getDryValue(), calibration.getWetValue());\n60:         display.showMessage(\"Calibration reset\");\n61:         Serial.println(\"Calibration reset\");\n62:       }\n63:     }\n64:   }\n65: \n66:   webServer.handleClient();\n67: \n68:   unsigned long now = millis();\n69: \n70:   if (now - lastSensorRead >= 2000) {\n71:     lastMoisture = sensor.readPercent();\n72:     lastRaw = sensor.readRaw();\n73:     lastWifiStatus = WiFi.status() == WL_CONNECTED ? \"connected\" : (WiFi.getMode() == WIFI_AP ? \"ap\" : \"disconnected\");\n74:     lastSensorRead = now;\n75:   }\n76: \n77:   if (now - lastDisplayUpdate >= 10000) {\n78:     if (calibrating) {\n79:       display.showCalibrationScreen();\n80:     } else {\n81:       display.showStatus(lastMoisture, lastRaw, calibrating, lastWifiStatus.c_str());\n82:     }\n83:     lastDisplayUpdate = now;\n84:   }\n85: \n86:   delay(10);\n87: }\n88: ",
