        "content": "Read lib/WebServer/index.h (lines 201-431 of 431, 11145 bytes)\n201:   border: none;\n202:   border-radius: 8px;\n203:   font-weight: bold;\n204:   cursor: pointer;\n205:   margin-top: 10px;\n206: }\n207: .modal-content button:hover {\n208:   background: #0097a7;\n209: }\n210: .close {\n211:   float: right;\n212:   font-size: 1.5rem;\n213:   cursor: pointer;\n214:   color: #aaa;\n215: }\n216: .close:hover {\n217:   color: #eee;\n218: }\n219: </style>\n220: </head>\n221: <body>\n222: <div class=\"container\">\n223:   <div style=\"position: relative;\">\n224:     <div class=\"wifi-status\" id=\"wifiStatus\">WiFi: --</div>\n225:     <button class=\"settings-btn\" onclick=\"openModal()\">&#9881;</button>\n226:   </div>\n227:   <div class=\"sensors-wrapper\" id=\"sensorContainer\"></div>\n228:   <div class=\"message\" id=\"message\"></div>\n229: </div>\n230: \n231: <!-- Settings Modal -->\n232: <div id=\"settingsModal\" class=\"modal\">\n233:   <div class=\"modal-content\">\n234:     <span class=\"close\" onclick=\"closeModal()\">&times;</span>\n235:     <h3>WiFi Settings</h3>\n236:     <label for=\"wifiSsid\">SSID:</label>\n237:     <input type=\"text\" id=\"wifiSsid\" placeholder=\"Enter WiFi SSID\">\n238:     <label for=\"wifiPass\">Password:</label>\n239:     <input type=\"password\" id=\"wifiPass\" placeholder=\"Enter WiFi Password\">\n240:     <button onclick=\"saveWifi()\">Save and Reboot</button>\n241:     <div id=\"wifiStatusModal\"></div>\n242:   </div>\n243: </div>\n244: \n245: <script>\n246: (function(){\n247:   const circumference = 2 * Math.PI * 56; // r=56 for 120px gauge\n248:   const messageDiv = document.getElementById('message');\n249:   const sensorContainer = document.getElementById('sensorContainer');\n250:   const wifiStatus = document.getElementById('wifiStatus');\n251:   \n252:   // Store references to cards\n253:   const cards = {};\n254: \n255:   function createOrUpdateSensorCard(index, data) {\n256:     let card = cards[index];\n257:     if (!card) {\n258:       // Create card\n259:       card = document.createElement('div');\n260:       card.className = 'card';\n261:       card.innerHTML = `\n262:         <input class=\"name-input\" id=\"name-${index}\" value=\"${data.name}\" />\n263:         <div class=\"gauge-wrapper\">\n264:           <div class=\"gauge\">\n265:             <svg viewBox=\"0 0 120 120\">\n266:               <circle class=\"bg\" cx=\"60\" cy=\"60\" r=\"56\"/>\n267:               <circle class=\"fg\" id=\"gauge-${index}\" cx=\"60\" cy=\"60\" r=\"56\" stroke-dasharray=\"${circumference}\" stroke-dashoffset=\"${circumference}\"/>\n268:             </svg>\n269:             <div class=\"gauge-value\" id=\"gauge-value-${index}\">0%</div>\n270:           </div>\n271:         </div>\n272:         <div class=\"metrics\">\n273:           <div class=\"metric\"><span class=\"label\">Raw</span><span class=\"value\" id=\"raw-${index}\">${data.raw}</span></div>\n274:           <div class=\"metric\"><span class=\"label\">Voltage</span><span class=\"value\" id=\"voltage-${index}\">${data.voltage}V</span></div>\n275:         </div>\n276:         <div class=\"btn-group\">\n277:           <button class=\"btn\" onclick=\"calibrateDry(${index})\">Dry</button>\n278:           <button class=\"btn\" onclick=\"calibrateWet(${index})\">Wet</button>\n279:           <button class=\"btn\" onclick=\"calibrateReset(${index})\">Reset</button>\n280:         </div>\n281:       `;\n282:       sensorContainer.appendChild(card);\n283:       cards[index] = card;\n284:       \n285:       // Add event listener for name change\n286:       const nameInput = card.querySelector(`#name-${index}`);\n287:       nameInput.addEventListener('change', function() {\n288:         const newName = this.value;\n289:         fetch(`/api/config/sensor?index=${index}`, {\n290:           method: 'POST',\n291:           headers: {'Content-Type': 'application/json'},\n292:           body: JSON.stringify({name: newName})\n293:         }).then(() => {\n294:           messageDiv.textContent = 'Name updated for sensor ' + index;\n295:           setTimeout(() => { messageDiv.textContent = ''; }, 2000);\n296:         }).catch(err => {\n297:           messageDiv.textContent = 'Error updating name';\n298:         });\n299:       });\n300:     }\n301:     // Update card elements\n302:     const fgCircle = card.querySelector(`#gauge-${index}`);\n303:     const gaugeValue = card.querySelector(`#gauge-value-${index}`);\n304:     const rawSpan = card.querySelector(`#raw-${index}`);\n305:     const voltageSpan = card.querySelector(`#voltage-${index}`);\n306:     const nameInput = card.querySelector(`#name-${index}`);\n307:     \n308:     if (data.percentage !== undefined) {\n309:       const offset = circumference - (data.percentage / 100) * circumference;\n310:       fgCircle.style.strokeDashoffset = offset;\n311:       gaugeValue.textContent = Math.round(data.percentage) + '%';\n312:     }\n313:     rawSpan.textContent = data.raw;\n314:     voltageSpan.textContent = (data.voltage).toFixed(2) + 'V';\n315:     if (data.name && nameInput.value !== data.name) {\n316:       nameInput.value = data.name;\n317:     }\n318:   }\n319: \n320:   // SSE connection\n321:   let eventSource = null;\n322:   function connectSSE() {\n323:     if (eventSource) eventSource.close();\n324:     eventSource = new EventSource('/events');\n325:     eventSource.addEventListener('status', function(e) {\n326:       try {\n327:         const data = JSON.parse(e.data);\n328:         if (data.sensors) {\n329:           data.sensors.forEach((sensor, index) => {\n330:             createOrUpdateSensorCard(index, sensor);\n331:           });\n332:         }\n333:         if (data.wifi) {\n334:           wifiStatus.textContent = 'WiFi: ' + data.wifi;\n335:         }\n336:       } catch(err) {\n337:         console.error('SSE parse error', err);\n338:       }\n339:     });\n340:     eventSource.onerror = function() {\n341:       eventSource.close();\n342:       setTimeout(connectSSE, 3000);\n343:     };\n344:   }\n345:   connectSSE();\n346: \n347:   // Calibration functions\n348:   function calibrateDry(index) {\n349:     messageDiv.textContent = 'Setting dry for sensor ' + index + '...';\n350:     fetch(`/api/calibrate/dry?index=${index}`, { method: 'POST' })\n351:       .then(async response => {\n352:         const text = await response.text();\n353:         messageDiv.textContent = text;\n354:         setTimeout(() => { messageDiv.textContent = ''; }, 2000);\n355:       })\n356:       .catch(err => {\n357:         messageDiv.textContent = 'Error: ' + err;\n358:       });\n359:   }\n360:   function calibrateWet(index) {\n361:     messageDiv.textContent = 'Setting wet for sensor ' + index + '...';\n362:     fetch(`/api/calibrate/wet?index=${index}`, { method: 'POST' })\n363:       .then(async response => {\n364:         const text = await response.text();\n365:         messageDiv.textContent = text;\n366:         setTimeout(() => { messageDiv.textContent = ''; }, 2000);\n367:       })\n368:       .catch(err => {\n369:         messageDiv.textContent = 'Error: ' + err;\n370:       });\n371:   }\n372:     function calibrateReset(index) {\n373:     messageDiv.textContent = 'Resetting calibration for sensor ' + index + '...';\n374:     fetch(`/api/calibrate/reset?index=${index}`, { method: 'POST' })\n375:       .then(async response => {\n376:         const text = await response.text();\n377:         messageDiv.textContent = text;\n378:         setTimeout(() => { messageDiv.textContent = ''; }, 2000);\n379:       })\n380:       .catch(err => {\n381:         messageDiv.textContent = 'Error: ' + err;\n382:       });\n383:   }\n384: \n385:   // Settings modal functions\n386:   function openModal() {\n387:     document.getElementById('settingsModal').style.display = 'flex';\n388:     fetch('/api/wifi')\n389:       .then(response => response.json())\n390:       .then(data => {\n391:         document.getElementById('wifiSsid').value = data.ssid || '';\n392:       })\n393:       .catch(() => {});\n394:   }\n395:   function closeModal() {\n396:     document.getElementById('settingsModal').style.display = 'none';\n397:   }\n398:   function saveWifi() {\n399:     const ssid = document.getElementById('wifiSsid').value.trim();\n400:     const pass = document.getElementById('wifiPass').value.trim();\n401:     if (!ssid) {\n402:       alert('SSID cannot be empty');\n403:       return;\n404:     }\n405:     const btn = document.querySelector('.modal-content button');\n406:     btn.disabled = true;\n407:     btn.textContent = 'Rebooting...';\n408:     fetch('/api/config/wifi', {\n409:       method: 'POST',\n410:       headers: {'Content-Type': 'application/json'},\n411:       body: JSON.stringify({ssid, pass})\n412:     })\n413:     .then(response => response.text())\n414:     .then(text => {\n415:       document.getElementById('wifiStatusModal').textContent = text;\n416:     })\n417:     .catch(err => {\n418:       document.getElementById('wifiStatusModal').textContent = 'Error: ' + err;\n419:       btn.disabled = false;\n420:       btn.textContent = 'Save and Reboot';\n421:     });\n422:   }\n423: })();\n424: })();\n425: </script>\n426: </body>\n427: </html>\n428: )rawliteral\";\n429: \n430: #endif\n431: ",
