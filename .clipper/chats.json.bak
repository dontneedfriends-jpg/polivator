          "file": "lib/WebServer/WebServer.cpp",
          "oldString": "// Handle 404\n  server.onNotFound([](AsyncWebServerRequest *request) {",
          "newString": "}\n\n// static method to get index from query\nint WebServer::getIndexFromParam(AsyncWebServerRequest *request) {\n  if (!request->hasParam(\"index\")) {\n    return -1;\n  }\n  String indexStr = request->getParam(\"index\")->value();\n  int index = indexStr.toInt();\n  if (index < 0 || index >= MAX_SENSORS) {\n    return -1;\n  }\n  return index;\n}\n\nvoid WebServer::handleUpdate(AsyncWebServerRequest *request, String filename, size_t index, uint8_t *data, size_t len, bool final) {\n  if (!index) {\n    if (!Update.begin(UPDATE_SIZE_UNKNOWN)) {\n      m_updateInProgress = false;\n      return request->send(500, \"text/plain\", \"Update begin failed\");\n    }\n    m_updateStartTime = millis();\n    Serial.printf(\"OTA update started: %s\\n\", filename.c_str());\n  }\n  // Check timeout (60 seconds)\n  if (millis() - m_updateStartTime > 60000) {\n    Update.abort();\n    m_updateInProgress = false;\n    request->send(408, \"text/plain\", \"Update timeout\");\n    return;\n  }\n  if (Update.write(data, len) != len) {\n    Update.abort();\n    m_updateInProgress = false;\n    return request->send(500, \"text/plain\", \"Write error\");\n  }\n  if (final) {\n    if (Update.end(true)) {\n      Serial.println(\"OTA update success! Rebooting...\");\n      m_updateInProgress = false;\n      request->send(200, \"text/plain\", \"Update success. Rebooting...\");\n      delay(500);\n      ESP.restart();\n    } else {\n      Serial.printf(\"Update error: %s\\n\", Update.errorString());\n      m_updateInProgress = false;\n      request->send(500, \"text/plain\", \"Update failed: \" + String(Update.errorString()));\n    }\n  }\n}\n\n// Handle 404\n  server.onNotFound([](AsyncWebServerRequest *request) {"
