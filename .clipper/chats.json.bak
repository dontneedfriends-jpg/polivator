        "content": "Read src/main.cpp (lines 1-200 of 222, 7124 bytes)\n  1: #include <Arduino.h>\n  2: #include <WiFi.h>\n  3: #include <ArduinoOTA.h>\n  4: #include <esp_task_wdt.h>\n  5: #include \"Sensor.h\"\n  6: #include \"Calibration.h\"\n  7: #include \"Display.h\"\n  8: #include \"WebServer.h\"\n  9: #include \"Settings.h\"\n 10: #include \"Common/Types.h\"\n 11: \n 12: // Пять датчиков на GPIO6-10 (ADC1)\n 13: // WARNING: GPIO6-10 are strapping pins and may cause boot issues if used with external flash.\n 14: const uint8_t sensorPins[MAX_SENSORS] = {6, 7, 8, 9, 10};\n 15: \n 16: Calibration calibration;\n 17: SensorManager sensorManager;\n 18: Display display;\n 19: Settings settings;\n 20: WebServer webServer(&sensorManager, &calibration, &display, &settings);\n 21: \n 22: bool calibrating = false;\n 23: uint8_t activeSensorForSerial = 0; // индекс датчика для serial-калибровки\n 24: static bool forceDisplayUpdate = false;\n 25: \n 26: void setup() {\n 27:   Serial.begin(115200);\n 28:   delay(1000);\n 29:   esp_task_wdt_reset();\n 30:   Serial.println(\"\\n=== Polivator Multi-Sensor ===\");\n 31:   Serial.print(\"Sensor pins: \");\n 32:   for (int i = 0; i < MAX_SENSORS; i++) {\n 33:     if (i > 0) Serial.print(\", \");\n 34:     Serial.print(sensorPins[i]);\n 35:   }\n 36:   Serial.println();\n 37:   \n 38:   calibration.begin(sensorPins, MAX_SENSORS);\n 39:   esp_task_wdt_reset();\n 40:   sensorManager.begin(&calibration);\n 41:   esp_task_wdt_reset();\n 42:   display.begin();\n 43:   esp_task_wdt_reset();\n 44:   webServer.begin();\n 45:   esp_task_wdt_reset();\n 46:   ArduinoOTA.begin();\n 47:   esp_task_wdt_reset();\n 48:   \n 49:   // Отобразить статус после запуска\n 50:   sensorManager.readAll();\n 51:   {\n 52:     uint8_t count = sensorManager.getCount();\n 53:     const SensorConfig* configs = calibration.getConfigs();\n 54:     int percentages[MAX_SENSORS];\n 55:     int rawValues[MAX_SENSORS];\n 56:     for (uint8_t i = 0; i < count; i++) {\n 57:       percentages[i] = sensorManager.getPercent(i);\n 58:       rawValues[i] = sensorManager.getRaw(i);\n 59:     }\n 60:     const char* wifiStatus = WiFi.status() == WL_CONNECTED ? \"connected\" : (WiFi.getMode() == WIFI_AP ? \"ap\" : \"disconnected\");\n 61:     display.showStatus(count, configs, percentages, rawValues, wifiStatus);\n 62:   }\n 63:   esp_task_wdt_reset();\n 64:   Serial.println(\"Setup complete.\");\n 65: }\n 66: \n 67: void handleSerialCommands() {\n 68:   if (!Serial.available()) return;\n 69:   char c = Serial.read();\n 70:   \n 71:   if (c == 'c' || c == 'C') {\n 72:     calibrating = !calibrating;\n 73:     if (calibrating) {\n 74:       Serial.println(\"Calibration mode ON. Select sensor: 0-\" + String(MAX_SENSORS-1));\n 75:       Serial.println(\"Send 0..4 to select sensor, then 'd' dry, 'w' wet, 'r' reset.\");\n 76:       display.showCalibrationScreen(\"Calibration mode\");\n 77:     } else {\n 78:       Serial.println(\"Calibration mode OFF\");\n 79:     }\n 80:     return;\n 81:   }\n 82:   \n 83:   if (!calibrating) return;\n 84:   \n 85:   // Выбор датчика цифрой 0-4\n 86:   if (c >= '0' && c <= '4') {\n 87:     activeSensorForSerial = c - '0';\n 88:     Serial.print(\"Selected sensor #\");\n 89:     Serial.println(activeSensorForSerial);\n 90:     char buf[32];\n 91:     snprintf(buf, sizeof(buf), \"Sensor %u\", activeSensorForSerial);\n 92:     display.showMessage(buf);\n 93:     return;\n 94:   }\n 95:   \n 96:   uint8_t idx = activeSensorForSerial;\n 97:   \n 98:   if (c == 'd') {\n 99:     int raw = sensorManager.getRaw(idx);\n100:     calibration.setDryValue(idx, raw);\n101:     sensorManager.setCalibration(idx, calibration.getDryValue(idx), calibration.getWetValue(idx));\n102:     {\n103:       char buf[32];\n104:       snprintf(buf, sizeof(buf), \"Dry set S%u\", idx);\n105:       display.showMessage(buf);\n106:     }\n107:     forceDisplayUpdate = true;\n108:     Serial.print(\"Dry calibration set for sensor \");\n109:     Serial.println(idx);\n110:   } else if (c == 'w') {\n111:     int raw = sensorManager.getRaw(idx);\n112:     calibration.setWetValue(idx, raw);\n113:     sensorManager.setCalibration(idx, calibration.getDryValue(idx), calibration.getWetValue(idx));\n114:     {\n115:       char buf[32];\n116:       snprintf(buf, sizeof(buf), \"Wet set S%u\", idx);\n117:       display.showMessage(buf);\n118:     }\n119:     forceDisplayUpdate = true;\n120:     Serial.print(\"Wet calibration set for sensor \");\n121:     Serial.println(idx);\n122:   } else if (c == 'r') {\n123:     calibration.resetToDefaults(idx);\n124:     sensorManager.setCalibration(idx, calibration.getDryValue(idx), calibration.getWetValue(idx));\n125:     {\n126:       char buf[32];\n127:       snprintf(buf, sizeof(buf), \"Reset S%u\", idx);\n128:       display.showMessage(buf);\n129:     }\n130:     forceDisplayUpdate = true;\n131:     Serial.print(\"Calibration reset for sensor \");\n132:     Serial.println(idx);\n133:   } else if (c == 's') {\n134:     // Показать статус всех датчиков\n135:     for (int i = 0; i < MAX_SENSORS; i++) {\n136:       Serial.print(\"S\");\n137:       Serial.print(i);\n138:       Serial.print(\": raw=\");\n139:       Serial.print(sensorManager.getRaw(i));\n140:       Serial.print(\" %=\");\n141:       Serial.print(sensorManager.getPercent(i));\n142:       Serial.print(\" dry=\");\n143:       Serial.print(calibration.getDryValue(i));\n144:       Serial.print(\" wet=\");\n145:       Serial.print(calibration.getWetValue(i));\n146:       Serial.print(\" pin=\");\n147:       Serial.println(calibration.getPin(i));\n148:     }\n149:   }\n150: }\n151: \n152: void loop() {\n153:   esp_task_wdt_reset();\n154:   static unsigned long lastSensorRead = 0;\n155:   static unsigned long lastDisplayUpdate = 0;\n156:   \n157:   handleSerialCommands();\n158:   webServer.handleClient();\n159:   ArduinoOTA.handle();\n160:   esp_task_wdt_reset();\n161:   \n162:   unsigned long now = millis();\n163:   \n164:   // Чтение датчиков каждые 2 секунды\n165:   if (now - lastSensorRead >= 2000) {\n166:     sensorManager.readAll();\n167:     // Отправить SSE\n168:     webServer.sendStatusEvent(&sensorManager);\n169:     lastSensorRead = now;\n170:     esp_task_wdt_reset();\n171:   }\n172:   \n173:   // Обнаружение изменений конфигурации (калибровочных значений)\n174:   static bool configInit = false;\n175:   static int prevDry[MAX_SENSORS];\n176:   static int prevWet[MAX_SENSORS];\n177:   if (!configInit) {\n178:     for (uint8_t i = 0; i < MAX_SENSORS; i++) {\n179:       prevDry[i] = calibration.getDryValue(i);\n180:       prevWet[i] = calibration.getWetValue(i);\n181:     }\n182:     configInit = true;\n183:   }\n184:   bool configChanged = false;\n185:   for (uint8_t i = 0; i < MAX_SENSORS; i++) {\n186:     if (calibration.getDryValue(i) != prevDry[i] || calibration.getWetValue(i) != prevWet[i]) {\n187:       configChanged = true;\n188:       prevDry[i] = calibration.getDryValue(i);\n189:       prevWet[i] = calibration.getWetValue(i);\n190:     }\n191:   }\n192:   if (configChanged) {\n193:     forceDisplayUpdate = true;\n194:   }\n195:   \n196:   // Обновление дисплея каждые 30 секунд или при принудительном обновлении\n197:   if (now - lastDisplayUpdate >= 30000 || forceDisplayUpdate) {\n198:     forceDisplayUpdate = false;\n199:     if (calibrating) {\n200:       display.showCalibrationScreen(\"Calibration mode\");\n-- More: 22 lines below. Use offset=201 to continue. --",
