onScreen(const char* step) {\n56:   m_display.setFullWindow();\n57:   m_display.fillScreen(GxEPD_WHITE);\n58:   m_display.setTextColor(GxEPD_BLACK);\n59:   m_display.setFont(&FreeSans12pt7b);\n60:   \n61:   int16_t tbx, tby; uint16_t tbw, tbh;\n62:   // Center \"Calibrating...\" at top\n63:   m_display.getTextBounds(\"Calibrating...\", 0, 0, &tbx, &tby, &tbw, &tbh);\n64:   m_display.setCursor((m_display.width() - tbw) / 2, tbh + 10);\n65:   m_display.println(\"Calibrating...\");\n66:   \n67:   // Display step below if provided\n68:   if (step && step[0]) {\n69:     m_display.setFont(&FreeSans9pt7b);\n70:     m_display.getTextBounds(step, 0, 0, &tbx, &tby, &tbw, &tbh);\n71:     m_display.setCursor((m_display.width() - tbw) / 2, m_display.height() / 2);\n72:     m_display.println(step);\n73:   }\n74:   \n75:   m_display.display(false);\n76: }\n77: \n78: void Display::showMessage(const char* msg) {\n79:   m_display.setFullWindow();\n80:   m_display.fillScreen(GxEPD_WHITE);\n81:   m_display.setTextColor(GxEPD_BLACK);\n82:   m_display.setFont(&FreeSans9pt7b);\n83:   \n84:   int16_t tbx, tby; uint16_t tbw, tbh;\n85:   m_display.getTextBounds(msg, 0, 0, &tbx, &tby, &tbw, &tbh);\n86:   m_display.setCursor((m_display.width() - tbw) / 2, (m_display.height() + tbh) / 2);\n87:   m_display.println(msg);\n88:   \n89:   m_display.display(false);\n90: }\n91: \n92: void Display::deepSleep() {\n93:   m_display.powerDown(); // or m_display.hibernate()? powerDown is enough\n94:   // Optionally: m_display.sleep(); // but powerDown may be sufficient\n95: }\n96: ",
