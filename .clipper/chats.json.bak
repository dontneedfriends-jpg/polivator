e(i);\n 59:     sensor[\"dry\"] = m_calibration->getDryValue(i);\n 60:     sensor[\"wet\"] = m_calibration->getWetValue(i);\n 61:   }\n 62:   doc[\"wifi\"] = WiFi.status() == WL_CONNECTED ? \"connected\" : (WiFi.getMode() == WIFI_AP ? \"ap\" : \"disconnected\");\n 63:   String output;\n 64:   serializeJson(doc, output);\n 65:   events.send(output.c_str(), \"status\", millis());\n 66: }\n 67: \n 68: bool WebServer::connectToSavedWiFi() {\n 69:   String ssid = preferences.getString(\"ssid\", \"\");\n 70:   String pass = preferences.getString(\"pass\", \"\");\n 71:   if (ssid.length() == 0) return false;\n 72:   \n 73:   WiFi.mode(WIFI_STA);\n 74:   WiFi.begin(ssid.c_str(), pass.c_str());\n 75:   \n 76:   unsigned long startAttempt = millis();\n 77:   while (WiFi.status() != WL_CONNECTED && millis() - startAttempt < 10000) {\n 78:     delay(100);\n 79:   }\n 80:   \n 81:   return WiFi.status() == WL_CONNECTED;\n 82: }\n 83: \n 84: void WebServer::setupAP() {\n 85:   WiFi.mode(WIFI_AP);\n 86:   WiFi.softAP(\"Polivator-Config\");\n 87:   IPAddress apIP(192, 168, 4, 1);\n 88:   WiFi.softAPConfig(apIP, apIP, IPAddress(255, 255, 255, 0));\n 89:   \n 90:   dnsServer.start(53, \"*\", apIP);\n 91: }\n 92: \n 93: void WebServer::setupRoutes() {\n 94:   // Root: serve the web UI page\n 95:   server.on(\"/\", HTTP_GET, [this](AsyncWebServerRequest *request) {\n 96:     request->send(200, \"text/html\", index_html_content);\n 97:   });\n 98:   \n 99:   // GET /api/status\n100:   server.on(\"/api/status\", HTTP_GET, [this](AsyncWebServerRequest *request) {\n101:     AsyncResponseStream *response = request->beginResponseStream(\"application/json\");\n102:     JsonDocument doc;\n103:     JsonArray sensors = doc.createNestedArray(\"sensors\");\n104:     for (int i = 0; i < MAX_SENSORS; i++) {\n105:       JsonObject sensor = sensors.createNestedObject();\n106:       sensor[\"name\"] = m_calibration->getName(i);\n107:       sensor[\"raw\"] = m_sensorManager->readRaw(i);\n108:       sensor[\"percentage\"] = m_sensorManager->readPercent(i);\n109:       sensor[\"voltage\"] = m_sensorManager->readVoltage(i);\n110:       sensor[\"dry\"] = m_calibration->getDryValue(i);\n111:       sensor[\"wet\"] = m_calibration->getWetValue(i);\n112:     }\n113:     doc[\"wifi\"] = WiFi.status() == WL_CONNECTED ? \"connected\" : (WiFi.getMode() == WIFI_AP ? \"ap\" : \"disconnected\");\n114:     serializeJson(doc, *response);\n115:     request->send(response);\n116:   });\n117:   \n118:   // POST /api/calibrate/dry/{index}\n119:   server.on(\"/api/calibrate/dry/{index}\", HTTP_POST, [this](AsyncWebServerRequest *request) {\n120:     String indexStr = request->pathArg(0);\n121:     int index = indexStr.toInt();\n122:     if (index < 0 || index >= MAX_SENSORS) {\n123:       request->send(400, \"text/plain\", \"Invalid index\");\n124:       return;\n125:     }\n126:     int raw = m_sensorManager->readRaw(index);\n127:     m_calibration->setDryValue(index, raw);\n128:     m_sensorManager->setCalibration(index, m_calibration->getDryValue(index), m_calibration->getWetValue(index));\n129:     request->send(200, \"text/plain\", \"Dry threshold set for sensor \" + String(index));\n130:   });\n131:   \n132:   // POST /api/calibrate/wet/{index}\n133:   server.on(\"/api/calibrate/wet/{index}\", HTTP_POST, [this](AsyncWebServerRequest *request) {\n134:     String indexStr = request->pathArg(0);\n135:     int index = indexStr.toInt();\n136:     if (index < 0 || index >= MAX_SENSORS) {\n137:       request->send(400, \"text/plain\", \"Invalid index\");\n138:       return;\n139:     }\n140:     int raw = m_sensorManager->readRaw(index);\n141:     m_calibration->setWetValue(index, raw);\n142:     m_sensorManager->setCalibration(index, m_calibration->getDryValue(index), m_calibration->getWetValue(index));\n143:     request->send(200, \"text/plain\", \"Wet threshold set for sensor \" + String(index));\n144:   });\n145:   \n146:   // POST /api/calibrate/reset/{index}\n147:   server.on(\"/api/calibrate/reset/{index}\", HTTP_POST, [this](AsyncWebServerRequest *request) {\n148:     String indexStr = request->pathArg(0);\n149:     int index = indexStr.toInt();\n150:     if (index < 0 || index >= MAX_SENSORS) {\n151:       request->send(400, \"text/plain\", \"Invalid index\");\n152:       return;\n153:     }\n154:     m_calibration->resetToDefaults(index);\n155:     m_sensorManager->setCalibration(index, m_calibration->getDryValue(index), m_calibration->getWetValue(index));\n156:     request->send(200, \"text/plain\", \"Calibration reset for sensor \" + String(index));\n157:   });\n158:   \n159:   // POST /api/config/sensor/{index}\n160:   server.on(\"/api/config/sensor/{index}\", HTTP_POST, [this](AsyncWebServerRequest *request) {\n161:     String indexStr = request->pathArg(0);\n162:     int index = indexStr.toInt();\n163:     if (index < 0 || index >= MAX_SENSORS) {\n164:       request->send(400, \"text/plain\", \"Invalid index\");\n165:       return;\n166:     }\n167:     // Parse JSON body\n168:     if (request->contentType() != \"application/json\") {\n169:       request->send(400, \"text/plain\", \"Content-Type must be application/json\");\n170:       return;\n171:     }\n172:     String body = request->arg(\"plain\");\n173:     JsonDocument doc;\n174:     DeserializationError error = deserializeJson(doc, body);\n175:     if (error) {\n176:       request->send(400, \"text/plain\", \"Invalid JSON\");\n177:       return;\n178:     }\n179:     const char* name = doc[\"name\"];\n180:     if (name) {\n181:       m_calibration->setName(index, String(name));\n182:       request->send(200, \"text/plain\", \"Name set for sensor \" + String(index));\n183:     } else {\n184:       request->send(400, \"text/plain\", \"Missing 'name' field\");\n185:     }\n186:   });\n187:   \n188:   // GET /api/calibration\n189:   server.on(\"/api/calibration\", HTTP_GET, [this](AsyncWebServerRequest *request) {\n190:     AsyncResponseStream *response = request->beginResponseStream(\"application/json\");\n191:     JsonDocument doc;\n192:     JsonArray sensors = doc.createNestedArray(\"sensors\");\n193:     for (int i = 0; i < MAX_SENSORS; i++) {\n194:       JsonObject sensor = sensors.createNestedObject();\n195:       sensor[\"name\"] = m_calibration->getName(i);\n196:       sensor[\"dry\"] = m_calibration->getDryValue(i);\n197:       sensor[\"wet\"] = m_calibration->getWetValue(i);\n198:     }\n199:     serializeJson(doc, *response);\n200:     request->send(response);\n-- More: 61 lines below. Use offset=201 to continue. --",
